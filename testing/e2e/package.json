{
  "name": "@repo/e2e",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "e2e": "bun run e2e:web",
    "e2e:web": "playwright test --config=web/playwright.config.ts",
    "e2e:ui": "playwright test --ui",
    "e2e:report": "playwright show-report",
    "e2e:report:web": "playwright show-report web/playwright-report",
    "install:browsers": "playwright install",
    "install:chromium": "playwright install chromium",
    "install:firefox": "playwright install firefox",
    "install:webkit": "playwright install webkit"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@repo/typescript": "workspace:*",
    "typescript": "^6.0.3",
    "web": "workspace:*"
  }
}
