{
  "name": "@repo/database",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "database:generate": "bunx prisma generate",
    "database:migrate:dev": "bunx prisma migrate dev",
    "database:migrate": "bunx prisma migrate deploy",
    "database:push": "bunx prisma db push",
    "database:studio": "bunx prisma studio",
    "database:reset": "bunx prisma migrate reset",
    "lint": "eslint . --max-warnings 0",
    "typecheck": "tsc --noEmit",
    "postinstall": "bunx prisma generate",
    "setup:env": "bun ../../packages/env/setup-env.ts .env.backend:.env"
  },
  "exports": {
    ".": "./src/index.ts"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@repo/env": "workspace:*",
    "dotenv": "^17.4.2"
  },
  "devDependencies": {
    "@repo/eslint": "workspace:*",
    "@repo/typescript": "workspace:*",
    "@types/pg": "^8.20.0",
    "prisma": "^7.8.0"
  }
}
