{
  "name": "backend",
  "version": "1.0.0",
  "description": "Hono API backend with OpenAPI and Auth.",
  "type": "module",
  "scripts": {
    "dev": "bun run --hot src/bun.ts",
    "console": "bun ./src/console.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint --max-warnings 0",
    "prisma:better-auth-generate": "bunx @better-auth/cli generate --config ./src/services/auth.ts",
    "test": "bun test --env-file .env.test",
    "test:ci": "bun test --env-file .env.test --bail",
    "test:watch": "bun test --env-file .env.test --watch",
    "test:coverage": "bun test --env-file .env.test --coverage",
    "clean": "rimraf .eslintcache tsconfig.tsbuildinfo node_modules",
    "setup:env": "bun ../../packages/env/setup-env.ts .env.backend:.env"
  },
  "devDependencies": {
    "@repo/eslint": "workspace:*",
    "@repo/typescript": "workspace:*",
    "@types/bun": "latest",
    "@types/google-libphonenumber": "^7.4.30",
    "@types/lodash": "^4.17.24",
    "rimraf": "^6.1.3"
  },
  "dependencies": {
    "@hono/zod-openapi": "^1.3.0",
    "@repo/communications": "workspace:*",
    "@repo/database": "workspace:*",
    "@repo/env": "workspace:*",
    "@hono/zod-validator": "^0.7.6",
    "@logtape/hono": "^2.0.6",
    "@logtape/logtape": "^2.0.6",
    "@paralleldrive/cuid2": "^3.3.0",
    "@prisma/instrumentation": "^7.8.0",
    "@scalar/hono-api-reference": "^0.10.13",
    "better-auth": "^1.6.9",
    "commander": "^14.0.3",
    "google-libphonenumber": "^3.2.44",
    "hono": "^4.12.16",
    "lodash": "^4.18.1",
    "nanoid": "^5.1.11",
    "stoker": "^2.0.1",
    "zod": "^4.4.2"
  }
}
