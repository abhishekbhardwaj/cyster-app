{
  "name": "browser-extension",
  "description": "Browser Extension Boilerplate built with React and TypeScript, using Vite as the build tool and Playwright for end-to-end testing.",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "wxt",
    "dev:firefox": "wxt -b firefox",
    "build": "wxt build",
    "build:firefox": "wxt build -b firefox",
    "zip": "wxt zip",
    "zip:firefox": "wxt zip -b firefox",
    "compile": "tsc --noEmit",
    "postinstall": "wxt prepare",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "setup:env": "bun ../../packages/env/setup-env.ts .env.browser-extension:.env"
  },
  "dependencies": {
    "@repo/env": "workspace:*",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@repo/eslint": "workspace:*",
    "@repo/test-utils": "workspace:*",
    "@repo/typescript": "workspace:*",
    "@repo/vitest": "workspace:*",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@wxt-dev/module-react": "^1.2.2",
    "wxt": "^0.20.25"
  }
}
