{
  "name": "turbo-full-stack-monorepo",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --check \"**/*.{js,ts,tsx,md}\"",
    "format:fix": "prettier --write \"**/*.{js,ts,tsx,md}\"",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:e2e": "turbo run e2e --filter=@repo/e2e",
    "test:e2e:report": "bun run --filter=@repo/e2e e2e:report",
    "test:e2e:report:web": "bun run --filter=@repo/e2e e2e:report:web",
    "turbo:gen": "turbo gen",
    "commit": "cz",
    "database:generate": "turbo run database:generate",
    "database:migrate": "turbo run database:migrate",
    "database:migrate:dev": "turbo run database:migrate:dev --",
    "database:push": "turbo run database:push",
    "database:studio": "turbo run database:studio",
    "database:reset": "turbo run database:reset",
    "email:create": "turbo run email:create --",
    "email:check": "turbo run email:check",
    "email:preview": "turbo run email:preview",
    "clean": "git clean -xdf -e '.env*'",
    "update-all-dependencies": "bunx npm-check-updates --workspaces -u",
    "prepare": "is-ci || husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.3",
    "@commitlint/config-conventional": "^20.5.3",
    "@turbo/gen": "^2.9.9",
    "commitizen": "^4.3.1",
    "cz-conventional-changelog": "^3.3.0",
    "devmoji": "^2.3.0",
    "husky": "^9.1.7",
    "prettier": "^3.8.3",
    "turbo": "^2.9.9",
    "typescript": "6.0.3",
    "vitest": "^4.1.5"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "bun@1.3.13",
  "workspaces": [
    "apps/*",
    "packages/*",
    "tooling/*",
    "testing/*"
  ],
  "prettier": "@repo/prettier",
  "dependencies": {
    "@repo/prettier": "workspace:*",
    "is-ci": "^4.1.0"
  }
}
